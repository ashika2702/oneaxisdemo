# OneAxis Backend Configuration
# Copy to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oneaxis
DB_USER=oneaxis_user
DB_PASSWORD=your_secure_password

# Redis (caching + sessions)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d
BCRYPT_ROUNDS=12

# OpenAI (for document parsing)
OPENAI_API_KEY=sk-your-openai-api-key

# AWS S3 (file storage)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=oneaxis-uploads

# Optional: Unreal Pixel Streaming (for cinematic rendering tier)
UNREAL_STREAMING_URL=

# Email (for proposal notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Stripe (for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
